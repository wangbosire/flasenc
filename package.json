{
  "name": "flasenc",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "docker:dev": "docker compose up --build flasenc",
    "docker:up": "docker compose up -d --build flasenc",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f flasenc",
    "docker:shell": "docker compose exec flasenc bash",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.19"
  }
}
