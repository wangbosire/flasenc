{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/front/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/front/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/front",
  "projects": {
    "admin": {
      "type": "application",
      "root": "apps/admin",
      "entryFile": "main",
      "sourceRoot": "apps/admin/src",
      "compilerOptions": {
        "tsConfigPath": "apps/admin/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "front": {
      "type": "application",
      "root": "apps/front",
      "entryFile": "main",
      "sourceRoot": "apps/front/src",
      "compilerOptions": {
        "tsConfigPath": "apps/front/tsconfig.app.json"
      }
    },
    "http": {
      "type": "library",
      "root": "libs/http",
      "entryFile": "index",
      "sourceRoot": "libs/http/src",
      "compilerOptions": {
        "tsConfigPath": "libs/http/tsconfig.lib.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    }
  }
}
