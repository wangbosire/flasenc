# 本地开发 / Jest / E2E：本机 MySQL。标准路径不依赖 Docker；复制为 `.env` 后改成你本机账号口令。
# 若无 flasenc 库：在 apps/server 执行 `mysql -u root -p < scripts/create-flasenc-database.sql`（见 README）。
# 不要将含生产口令的 `.env` 提交仓库（已在 .gitignore）。
#
# 与 jest.setup.ts、e2e-db-migrate-deploy 默认一致：库 flasenc、端口 3306
DATABASE_URL="mysql://root:root123..@127.0.0.1:3306/flasenc"

# C 端与管理端 **access** JWT；生产须使用强随机值，勿提交真实 `.env`
JWT_SECRET="change-me-to-a-long-random-string-at-least-32-chars"

# **refresh** JWT 须独立密钥（与 access 分离）；生产务必显式配置
JWT_REFRESH_SECRET="change-me-to-another-long-random-string-at-least-32-chars"

# 微信小程序 **`POST /api/v1/auth/wechat/mini-program`**：服务端 **`jscode2session`**；不配置则该接口返回 **503**
WECHAT_MINI_PROGRAM_APPID=""
WECHAT_MINI_PROGRAM_SECRET=""

# 生产环境默认不挂载 Swagger UI；仅在受控环境需要 **`/docs`** 时设为 true
# SWAGGER_ENABLED=true
